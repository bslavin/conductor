# Conductor Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git

# ============================================
# Proxmox
# ============================================
PROXMOX_HOST=192.168.2.167
PROXMOX_PORT=8006
PROXMOX_API_TOKEN=

# ============================================
# Mem0 — Shared Agent Memory
# ============================================
MEM0_PORT=8070
MEM0_DB_USER=mem0
MEM0_DB_PASSWORD=
MEM0_DB_NAME=mem0
MEM0_NEO4J_PASSWORD=
MEM0_API_KEY=

# LLM providers (Mem0 uses these for memory extraction)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================
# Infisical — Secrets Management
# ============================================
INFISICAL_PORT=8080
INFISICAL_DB_USER=infisical
INFISICAL_DB_PASSWORD=
INFISICAL_DB_NAME=infisical
INFISICAL_ENCRYPTION_KEY=
INFISICAL_AUTH_SECRET=
INFISICAL_SITE_URL=http://infisical.conductor.local

# ============================================
# Google Ads MCP
# ============================================
GOOGLE_ADS_MCP_PORT=3100
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ============================================
# Oliver (Marketing Agent)
# ============================================
OLIVER_ANTHROPIC_API_KEY=
OLIVER_TELEGRAM_BOT_TOKEN=
OLIVER_PERPLEXITY_API_KEY=
